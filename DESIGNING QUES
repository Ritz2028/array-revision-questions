Implement MyHashSet class:

void add(key) Inserts the value key into the HashSet.
bool contains(key) Returns whether the value key exists in the HashSet or not.
void remove(key) Removes the value key in the HashSet. If key does not exist in the HashSet, do nothing.

code:
class MyHashSet {
public:

    int size;
    vector<vector<int>> bucket;

    MyHashSet() {
        size = 1000;
        bucket.resize(size);
    }

    int hash(int key){
        return key % size; // for finding bucket no
    }

    void add(int key) {

        int index = hash(key);

        for(int x : bucket[index]){
            if(x == key)
                return; 
        }

        bucket[index].push_back(key);
    }

    void remove(int key) {

        int index = hash(key);

        for(int i = 0; i < bucket[index].size(); i++){
            if(bucket[index][i] == key){
                bucket[index].erase(bucket[index].begin() + i);
      //index dhundho then vector list mein traverse karo bucket[index] will give iterator          pointing to the first elemnt of th evector list +i will give the exact posn
                return;
            }
        }
    }

    bool contains(int key) {

        int index = hash(key);

        for(int x : bucket[index]){
            if(x == key)
                return true;
        }

        return false;
    }
};

